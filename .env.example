# Copy to .env and fill in. NEVER commit the real .env.
#
# LLM runtime for M2+.
# Default target is OpenRouter (OpenAI-compatible Responses API). Provider/model
# stay configurable so we can swap the model later without changing app code.
# To use the official Gemini API instead, set AGENT_PROVIDER=gemini (native path
# in app/models.py) and supply the corresponding key.
OPENAI_API_KEY=your_key_here

# Multi-agent runtime. `adk` makes the ADK router/analyst/skeptic/narrator graph
# the central path (Sessions & Memory via a persistent DatabaseSessionService).
# On any error (no key, ADK missing, LLM down) it falls back to the deterministic
# legacy path, so the app always answers. The code default is `legacy` so tests
# stay hermetic; set this in your .env to run agents locally.
AGENT_MODE=adk
AGENT_PROVIDER=openai
# M9: let the agent ITSELF invoke tools (ADK FunctionTool function-calling) instead
# of the deterministic Python dispatch. On by intent for the demo; dispatch stays
# the grounding fallback, so if the provider wobbles on function calling the answer
# is still grounded. Code default is off so the test suite stays deterministic.
AGENT_TOOL_CALLING=1
# M9 bonus: consume the same tools over MCP (app.mcp_server, previously orphan)
# via ADK's MCPToolset instead of in-process. Falls back to in-process tools if
# the MCP subprocess can't start. Off by default.
# AGENT_MCP_TOOLS=1
# ADK Session store. Defaults to the same SQLite file as the product turn store
# (APP_DB_PATH, default app/data/app.db) — "two decoupled stores, one file".
# Override to isolate the ADK session DB (async driver required):
# ADK_SESSION_DB_URL=sqlite+aiosqlite:///app/data/adk_sessions.db
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_WIRE_API=responses
LLM_MODEL=google/gemini-3.1-flash-lite
LLM_REVIEW_MODEL=google/gemini-3.1-flash-lite
LLM_REASONING_EFFORT=high
LLM_DISABLE_RESPONSE_STORAGE=true

# Data mode for tools: live | cache | auto  (auto = try live, fall back to fixture).
# Keep this at `cache` for deterministic demo/eval runs. `auto`/`live` hit
# yfinance, which fails in sandboxed/CI envs and falls back to the 3-point
# fixture card (flat charts). ticker_card reads TICKER_DATA_MODE first, then
# DATA_MODE, then defaults to cache.
TICKER_DATA_MODE=cache
DATA_MODE=cache

# Public positioning: personal investing assistant for retail investors.
# Do not hard-code a contest-track label into product copy.
